{
  "name": "@ziikoo/woa",
  "version": "2.4.0",
  "type": "module",
  "description": "WOA remote-only CLI and hosted Web entrypoint for WeChat Official Account MCP SaaS",
  "keywords": [
    "wechat",
    "mcp",
    "ai",
    "api",
    "typescript",
    "official-account"
  ],
  "author": "xwang152-jack <xwang152@163.com>",
  "license": "MIT",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./worker": {
      "types": "./dist/src/worker/index.d.ts",
      "import": "./dist/src/worker/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "web/dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vmxmy/wechat-official-account-mcp-private.git"
  },
  "homepage": "https://woa.ziikoo.app",
  "bugs": {
    "url": "https://github.com/vmxmy/wechat-official-account-mcp-private/issues"
  },
  "scripts": {
    "build": "npm run clean && tsc && npm run web:build",
    "build:prod": "npm run clean && tsc --project tsconfig.prod.json && npm run web:build",
    "dev": "wrangler dev",
    "prepublishOnly": "npm run build:prod",
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "test": "npm run build:prod && npm run test:contracts && node test-tools.js && node scripts/web-render-smoke.mjs && node scripts/worker-oauth-smoke.mjs",
    "test:contracts": "node --import tsx --test tests/cli-agent-workflow.test.mjs && node --import tsx --test tests/cli-api-capabilities.test.ts && node --import tsx --test tests/worker-backend-contracts.test.ts && node --import tsx --test tests/audit-regressions.test.ts",
    "test:package-node-lts": "node scripts/package-node-lts-smoke.mjs",
    "clean": "rm -rf dist web/dist",
    "pack:dry": "npm pack --dry-run",
    "build:full": "./scripts/build.sh",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:types": "wrangler types",
    "d1:migrate:local": "wrangler d1 migrations apply DB --local",
    "r2:lifecycle:media": "wrangler r2 bucket lifecycle add wechat-official-account-mcp-media woa-media-staging-30d staging/ --expire-days 30",
    "web:build": "vite build",
    "web:test": "npm run build:prod && node scripts/web-render-smoke.mjs",
    "web:dev": "vite --host 0.0.0.0",
    "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.3",
    "@astryxdesign/theme-stone": "0.1.3",
    "@clack/prompts": "0.11.0",
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "agents": "^0.17.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.3",
    "@eslint/js": "^9.25.0",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.18.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "lucide-react": "^0.511.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.106.0",
    "zustand": "^5.0.3"
  },
  "bin": {
    "woa": "dist/src/cli/woa.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
