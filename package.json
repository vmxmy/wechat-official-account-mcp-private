{
  "name": "@vmxmy/wechat-official-account-mcp",
  "version": "2.2.0",
  "type": "module",
  "description": "微信公众号 MCP 服务 - 为 AI 应用提供完整的微信公众号 API 集成（26个工具模块，含多租户管理工具）",
  "keywords": [
    "wechat",
    "mcp",
    "ai",
    "api",
    "typescript",
    "official-account"
  ],
  "author": "xwang152-jack <xwang152@163.com>",
  "license": "MIT",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vmxmy/wechat-official-account-mcp-private.git"
  },
  "homepage": "https://woa.ziikoo.app",
  "bugs": {
    "url": "https://github.com/vmxmy/wechat-official-account-mcp-private/issues"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "build:prod": "npm run clean && tsc --project tsconfig.prod.json",
    "dev": "wrangler dev",
    "prepublishOnly": "npm run build:prod",
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "test": "npm run build:prod && node test-tools.js",
    "clean": "rm -rf dist",
    "pack:dry": "npm pack --dry-run",
    "build:full": "./scripts/build.sh",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:types": "wrangler types",
    "d1:migrate:local": "wrangler d1 migrations apply wechat-official-account-mcp --local"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.17.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.18.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "lucide-react": "^0.511.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.106.0",
    "zustand": "^5.0.3"
  },
  "bin": {
    "woa": "dist/src/cli/woa.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
